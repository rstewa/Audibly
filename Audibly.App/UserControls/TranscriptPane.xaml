<?xml version="1.0" encoding="utf-8" ?>

<UserControl
    d:DesignHeight="600"
    d:DesignWidth="420"
    mc:Ignorable="d"
    x:Class="Audibly.App.UserControls.TranscriptPane"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:Audibly.App.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid CornerRadius="8" RequestedTheme="Dark">
        <Grid.Background>
            <AcrylicBrush
                FallbackColor="#CC1F1F1F"
                TintColor="#1F1F1F"
                TintOpacity="0.7" />
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  chapter header + status  -->
        <StackPanel
            Margin="16,12,16,8"
            Orientation="Vertical"
            Spacing="2">
            <TextBlock
                FontWeight="SemiBold"
                Text="{x:Bind Vm.ChapterTitle, Mode=OneWay}"
                TextTrimming="CharacterEllipsis" />
            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind Vm.StatusText, Mode=OneWay}"
                Visibility="{x:Bind Vm.HasStatusText, Mode=OneWay}" />
        </StackPanel>

        <!--  sentences  -->
        <ScrollViewer
            Grid.Row="1"
            Padding="8,0"
            ViewChanged="Scroll_ViewChanged"
            x:Name="Scroll">
            <ItemsRepeater ItemsSource="{x:Bind Vm.Sentences, Mode=OneWay}" x:Name="Repeater">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="0" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:TranscriptSegmentViewModel">
                        <Border
                            Background="{x:Bind ActiveBrush, Mode=OneWay}"
                            CornerRadius="4"
                            Margin="{x:Bind ParagraphMargin}"
                            Padding="8,4"
                            Tapped="Sentence_Tapped">
                            <TextBlock
                                IsTextSelectionEnabled="False"
                                Opacity="{x:Bind RowOpacity, Mode=OneWay}"
                                Text="{x:Bind Text}"
                                TextWrapping="Wrap"
                                x:Name="SentenceText" />
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <!--  placeholder overlay  -->
        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            MaxWidth="300"
            Spacing="12"
            VerticalAlignment="Center"
            Visibility="{x:Bind Vm.ShowPlaceholder, Mode=OneWay}">
            <FontIcon
                FontSize="28"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Glyph="&#xED1E;"
                HorizontalAlignment="Center" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                HorizontalAlignment="Center"
                Text="{x:Bind Vm.PlaceholderText, Mode=OneWay}"
                TextAlignment="Center"
                TextWrapping="Wrap" />
        </StackPanel>

        <!--  live "transcribing" tail  -->
        <StackPanel
            Grid.Row="2"
            Margin="16,4,16,8"
            Orientation="Horizontal"
            Spacing="8"
            Visibility="{x:Bind Vm.ShowPendingTail, Mode=OneWay}">
            <ProgressRing
                Height="16"
                IsActive="{x:Bind Vm.ShowPendingTail, Mode=OneWay}"
                Width="16" />
            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind Vm.PendingTailText, Mode=OneWay}"
                VerticalAlignment="Center" />
        </StackPanel>

        <!--  return-to-position chip  -->
        <Button
            Click="ReturnToPosition_Click"
            Content="Return to playback position"
            Grid.Row="3"
            HorizontalAlignment="Center"
            Margin="0,0,0,12"
            Visibility="{x:Bind Vm.IsAutoScrollSuspended, Mode=OneWay}" />
    </Grid>
</UserControl>
